// Fonction avec paramètres de type structure
struct Point {
    int x;
    int y;
};

int distance(struct Point p1, struct Point p2) {
    int dx, dy;
    dx = p1.x - p2.x;
    dy = p1.y - p2.y;
    return dx + dy;
}

int main(void) {
    struct Point a, b;
    int d;
    a.x = 0;
    a.y = 0;
    b.x = 10;
    b.y = 10;
    d = distance(a, b);
    return 0;
}
